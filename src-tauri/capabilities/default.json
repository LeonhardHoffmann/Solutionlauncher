{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "npm-script",
          "cmd": "npm",
          "args": true
        },
        {
          "name": "npx-script",
          "cmd": "npx",
          "args": true
        }
      ]
    }
  ]
}